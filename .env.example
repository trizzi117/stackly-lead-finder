# ─────────────────────────────────────────────────────────────
# Stackly Lead Finder — конфигурация. Скопируй в .env и заполни.
# ─────────────────────────────────────────────────────────────

# 1) Telegram MTProto — my.telegram.org → API development tools
#    Используется и для подключения аккаунтов тенантов (вход по QR).
TG_API_ID=
TG_API_HASH=
TG_SESSION=stackly_radar          # имя сессии для одиночного режима (src/worker.py)
TG_PHONE=                          # +7..., только при первом логине одиночного воркера

# 2) Платформенный Telegram-бот (наш) — создать у @BotFather.
#    Через него идут лиды + сообщения о биллинге/аккаунте в личку клиента.
PLATFORM_BOT_TOKEN=
PLATFORM_BOT_USERNAME=             # без @, для deep-link подключения (t.me/<username>?start=...)

# 3) LLM — OpenAI-совместимый (DeepSeek дёшево, или OpenAI). Платит платформа.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# 4) SaaS
SESSION_SECRET=change-me-to-a-long-random-string
DATABASE_URL=                      # пусто = SQLite (data/saas.db); прод: postgresql://...
BILLING_PROVIDER=manual            # manual | lava | cryptomus | yookassa
BILLING_WEBHOOK_SECRET=            # секрет для проверки вебхуков провайдера

# ── ниже — для одиночного режима (src/worker.py + dashboard/), необязательно ──
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=
BUSINESS_CONTEXT=Я Stackly — внедряю автоматизацию (n8n, CRM, Telegram-боты, сайты с заявками) для малого бизнеса в РФ.
ACTIVE_NICHE=automation_ru
HOT_THRESHOLD=70
DB_PATH=data/stackly.db
